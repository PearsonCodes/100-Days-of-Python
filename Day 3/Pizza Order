Day 3 Project - Pizza Order 

print("Welcome to Python Pizza Deliveries!")

size = input("What size pizza do you want? S, M or L: ").upper()
while size not in ["S", "M", "L"]:
    size = input("Please enter either 'S' for small, 'M' Medium or 'L' for large.").upper()


pepperoni = input("Do you want pepperoni on your pizza? Y or N: ").upper()
while pepperoni not in ["Y", "N"]:
    pepperoni = input("Please enter either 'Y' for yes or 'N'.").upper()


extra_cheese = input("Do you want extra cheese? Y or N: ").upper()
while extra_cheese not in ["Y", "N"]:
    extra_cheese = input("Please enter either 'Y' for yes or 'N' for no.").upper()


if size == "S":
    bill = 15
elif size == "M":
    bill = 20
elif size == "L":
    bill = 25

if pepperoni == "Y":
    bill += 3

if extra_cheese == "Y":
    bill += 1

print(f"Your final bill is: ${bill}.")
